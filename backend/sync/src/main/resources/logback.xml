<configuration>
    <!-- S4-3: Structured logging with MDC fields (requestId, storeId) -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [rid=%X{requestId:-}] [sid=%X{storeId:-}] - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <logger name="io.ktor" level="INFO"/>
    <logger name="com.zyntasolutions" level="DEBUG"/>
    <logger name="io.lettuce" level="INFO"/>
</configuration>
