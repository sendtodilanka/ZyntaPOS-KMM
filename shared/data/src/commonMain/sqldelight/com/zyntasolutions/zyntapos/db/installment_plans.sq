-- ============================================================
-- installment_plans.sq — Customer credit / installment plans
-- ============================================================

CREATE TABLE installment_plans (
    id               TEXT    NOT NULL PRIMARY KEY,
    order_id         TEXT    NOT NULL,
    customer_id      TEXT    NOT NULL REFERENCES customers(id),
    total_amount     REAL    NOT NULL,
    paid_amount      REAL    NOT NULL DEFAULT 0.0,
    remaining_amount REAL    NOT NULL,
    num_installments INTEGER NOT NULL DEFAULT 1,
    frequency        TEXT    NOT NULL DEFAULT 'MONTHLY',  -- 'WEEKLY' | 'BIWEEKLY' | 'MONTHLY'
    start_date       INTEGER NOT NULL,
    end_date         INTEGER,
    status           TEXT    NOT NULL DEFAULT 'ACTIVE',   -- 'ACTIVE' | 'COMPLETED' | 'DEFAULTED'
    notes            TEXT,
    created_at       INTEGER NOT NULL,
    updated_at       INTEGER NOT NULL,
    sync_status      TEXT    NOT NULL DEFAULT 'PENDING'
);

CREATE INDEX idx_installment_plans_customer ON installment_plans(customer_id);
CREATE INDEX idx_installment_plans_status   ON installment_plans(status);

CREATE TABLE installment_payments (
    id          TEXT    NOT NULL PRIMARY KEY,
    plan_id     TEXT    NOT NULL REFERENCES installment_plans(id),
    due_date    INTEGER NOT NULL,
    amount      REAL    NOT NULL,
    paid_amount REAL    NOT NULL DEFAULT 0.0,
    paid_at     INTEGER,
    status      TEXT    NOT NULL DEFAULT 'PENDING',  -- 'PENDING' | 'PAID' | 'OVERDUE' | 'PARTIAL'
    payment_id  TEXT,
    created_at  INTEGER NOT NULL,
    updated_at  INTEGER NOT NULL,
    sync_status TEXT    NOT NULL DEFAULT 'PENDING'
);

CREATE INDEX idx_installment_payments_plan    ON installment_payments(plan_id);
CREATE INDEX idx_installment_payments_due     ON installment_payments(due_date, status);

-- ── Installment plan read queries ────────────────────────────────────────────

getInstallmentPlansByCustomer:
SELECT * FROM installment_plans WHERE customer_id = ? ORDER BY created_at DESC;

getInstallmentPlanById:
SELECT * FROM installment_plans WHERE id = ?;

getActiveInstallmentPlans:
SELECT * FROM installment_plans WHERE status = 'ACTIVE' ORDER BY start_date ASC;

getDueInstallmentPayments:
SELECT ip.* FROM installment_payments ip
WHERE ip.status IN ('PENDING', 'PARTIAL') AND ip.due_date <= ?
ORDER BY ip.due_date ASC;

-- ── Installment plan write queries ───────────────────────────────────────────

insertInstallmentPlan:
INSERT INTO installment_plans(id, order_id, customer_id, total_amount, paid_amount, remaining_amount, num_installments, frequency, start_date, end_date, status, notes, created_at, updated_at, sync_status)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateInstallmentPlan:
UPDATE installment_plans SET
    paid_amount = ?, remaining_amount = ?, status = ?, updated_at = ?, sync_status = 'PENDING'
WHERE id = ?;

-- ── Installment payment read queries ─────────────────────────────────────────

getPaymentsByPlan:
SELECT * FROM installment_payments WHERE plan_id = ? ORDER BY due_date ASC;

-- ── Installment payment write queries ────────────────────────────────────────

insertInstallmentPayment:
INSERT INTO installment_payments(id, plan_id, due_date, amount, paid_amount, paid_at, status, payment_id, created_at, updated_at, sync_status)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateInstallmentPayment:
UPDATE installment_payments SET
    paid_amount = ?, paid_at = ?, status = ?, payment_id = ?, updated_at = ?, sync_status = 'PENDING'
WHERE id = ?;
