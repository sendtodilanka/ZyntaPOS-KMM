VITE_API_URL=https://api.zyntapos.com
VITE_LICENSE_URL=https://license.zyntapos.com
VITE_SYNC_URL=https://sync.zyntapos.com

# Firebase Analytics (GA4) — TODO-011 Phase 2
# Leave blank to disable analytics (local dev / CI without Firebase project)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Web Push (VAPID) — FCM v1 / Browser Push Notifications
# The public key is safe to expose in the browser bundle.
# The private key must NEVER be placed here — store as GitHub Secret ZYNTA_FCM_VAPID_PRIVATE_KEY.
# Generate a VAPID key pair: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
