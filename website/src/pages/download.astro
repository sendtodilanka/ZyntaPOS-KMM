---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import CtaBanner from '@components/CtaBanner.astro';
import { company } from '@data/company';
import { buildBreadcrumbJsonLd, buildSoftwareApplicationJsonLd } from '@utils/seo';

const canonical = `${company.siteUrl}/download`;
const breadcrumbs = [{ name: 'Download', url: canonical }];

const platforms = [
  {
    name: 'Android',
    subtitle: 'Android 7.0+ (API 24)',
    description: 'Optimised for 10" tablets. Supports USB printers, barcode scanners, and cash drawers.',
    icon: 'android',
    badge: 'Most Popular',
    badgeColor: 'sky',
    downloads: [
      {
        label: 'Download APK',
        href: '/downloads/zyntapos-latest.apk',
        primary: true,
        note: 'v1.0.0 · ~35 MB',
      },
      {
        label: 'Google Play',
        href: company.playStore,
        primary: false,
        note: 'Auto-updates',
        external: true,
      },
    ],
    requirements: [
      'Android 7.0 (API 24) or higher',
      '10" tablet recommended (8" minimum)',
      '4 GB RAM recommended',
      '200 MB free storage',
    ],
  },
  {
    name: 'Windows',
    subtitle: 'Windows 10 / 11 (64-bit)',
    description: 'Full-featured desktop POS. Works with any USB or network printer and scanner.',
    icon: 'windows',
    badge: null,
    badgeColor: null,
    downloads: [
      {
        label: 'Download Installer (.exe)',
        href: '/downloads/zyntapos-windows-latest.exe',
        primary: true,
        note: 'v1.0.0 · ~45 MB',
      },
    ],
    requirements: [
      'Windows 10 or Windows 11 (64-bit)',
      '4 GB RAM minimum',
      '200 MB free storage',
      'Java 21 bundled — no separate install',
    ],
  },
  {
    name: 'macOS',
    subtitle: 'macOS 12 Monterey or later',
    description: 'Native desktop app for Mac. Supports Apple Silicon (M1/M2/M3) and Intel.',
    icon: 'macos',
    badge: null,
    badgeColor: null,
    downloads: [
      {
        label: 'Download DMG',
        href: '/downloads/zyntapos-macos-latest.dmg',
        primary: true,
        note: 'v1.0.0 · ~50 MB · Universal',
      },
    ],
    requirements: [
      'macOS 12 Monterey or later',
      'Apple Silicon or Intel Mac',
      '4 GB RAM minimum',
      '200 MB free storage',
    ],
  },
  {
    name: 'Linux',
    subtitle: 'Ubuntu 20.04+ / Debian-based',
    description: 'JVM desktop app. Runs on any Linux distro with Java 21+.',
    icon: 'linux',
    badge: null,
    badgeColor: null,
    downloads: [
      {
        label: 'Download .deb Package',
        href: '/downloads/zyntapos-linux-latest.deb',
        primary: true,
        note: 'v1.0.0 · ~42 MB',
      },
    ],
    requirements: [
      'Ubuntu 20.04+ or Debian 11+',
      '4 GB RAM minimum',
      '200 MB free storage',
      'Java 21 bundled — no separate install',
    ],
  },
];
---

<BaseLayout
  title="Download ZyntaPOS — Free POS for Android, Windows, macOS & Linux"
  description="Download ZyntaPOS free. Available for Android tablets (7.0+), Windows 10/11, macOS 12+, and Linux. Offline-first POS. No credit card required."
  canonical={canonical}
  keywords="download ZyntaPOS, POS app download, Android POS download, Windows POS software, free POS download"
  jsonLd={[buildSoftwareApplicationJsonLd(), buildBreadcrumbJsonLd(breadcrumbs)]}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <section class="bg-slate-900 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} />
      <div class="mt-8 mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Download ZyntaPOS
        </h1>
        <p class="mt-4 text-lg text-slate-400">
          Free for Android, Windows, macOS, and Linux. Works offline from day one. No credit card required.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-4 text-sm text-slate-500">
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            Current version: 1.0.0
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            AES-256 encrypted
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            Starter plan free forever
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Download cards -->
  <section class="py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {platforms.map((platform) => (
          <div class="relative flex flex-col rounded-2xl border border-slate-700/50 bg-slate-800/30 p-6 hover:border-sky-500/30 transition-colors">
            {platform.badge && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="inline-flex items-center rounded-full bg-sky-500 px-3 py-1 text-xs font-semibold text-white shadow">
                  {platform.badge}
                </span>
              </div>
            )}

            <!-- Platform icon -->
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl border border-slate-700/50 bg-slate-800">
              {platform.icon === 'android' && (
                <svg class="h-7 w-7 text-sky-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.523 15.341a1 1 0 01-1 1H7.477a1 1 0 01-1-1V9.001a1 1 0 011-1h9.046a1 1 0 011 1v6.34zM14.5 6.001l1.293-2.236a.5.5 0 00-.866-.5L13.573 5.5a5.5 5.5 0 00-3.146 0L9.073 3.265a.5.5 0 10-.866.5L9.5 6.001A6.002 6.002 0 006 11.5v.5h12v-.5a6.002 6.002 0 00-3.5-5.499zM10 10a1 1 0 110-2 1 1 0 010 2zm4 0a1 1 0 110-2 1 1 0 010 2z"/>
                </svg>
              )}
              {platform.icon === 'windows' && (
                <svg class="h-6 w-6 text-sky-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.551H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>
                </svg>
              )}
              {platform.icon === 'macos' && (
                <svg class="h-6 w-6 text-sky-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 18c-4.418 0-8-3.582-8-8s3.582-8 8-8 8 3.582 8 8-3.582 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
                </svg>
              )}
              {platform.icon === 'linux' && (
                <svg class="h-6 w-6 text-sky-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.4 1.289-.u865.316-.468.437-1.08.412-1.743-.015-.369-.071-.788-.095-1.087-.08-1.053.226-1.889.765-2.482.543-.596.946-1.304.994-2.159.05-.882-.222-1.812-.5-2.646-.279-.838-.579-1.632-.583-2.333-.004-.749.363-1.336.764-2.092.39-.733.94-1.698 1.199-3.114.264-1.419.143-3.327-.42-4.79C14.992.61 13.73.001 12.504.001zm.002 3.339c.546 0 1.048.134 1.498.39.908.514 1.457 1.5 1.492 2.596.036 1.108-.475 2.248-1.26 2.975-.793.735-1.832 1.096-2.877 1.046-.85-.04-1.64-.378-2.145-.947-.69-.783-.937-1.96-.687-3.099.246-1.136.956-2.13 1.87-2.617.41-.22.843-.344 1.109-.344zm-.04 1.02c-.166 0-.359.055-.574.168-.578.315-1.118 1.071-1.3 1.89-.17.793-.007 1.623.467 2.183.344.394.879.626 1.506.657.792.037 1.629-.253 2.255-.82.614-.558 1.028-1.429 1.003-2.28-.02-.768-.436-1.5-1.125-1.887-.375-.212-.797-.31-1.232-.31zm-2.78 7.64c.4 0 .797.08 1.184.238.39.162.734.4 1.016.719a2.966 2.966 0 01.689 1.62c.063.6-.013 1.168-.228 1.647a2.25 2.25 0 01-.977 1.069c-.43.232-.94.346-1.48.32-.56-.028-1.092-.193-1.533-.482a3.07 3.07 0 01-1.003-1.174 3.11 3.11 0 01-.284-1.595c.054-.574.27-1.112.608-1.534a2.716 2.716 0 012.008-.828zm4.56.014c.765 0 1.483.29 2.004.814.512.516.802 1.222.8 1.96-.002.716-.285 1.42-.794 1.944-.52.535-1.245.836-2.014.836-.748 0-1.461-.29-1.978-.8a2.72 2.72 0 01-.82-1.963c0-.744.296-1.454.818-1.968a2.742 2.742 0 011.984-.823z"/>
                </svg>
              )}
            </div>

            <h2 class="text-lg font-bold text-white">{platform.name}</h2>
            <p class="mt-1 text-xs text-slate-500">{platform.subtitle}</p>
            <p class="mt-3 text-sm text-slate-400 leading-relaxed flex-1">{platform.description}</p>

            <!-- Download buttons -->
            <div class="mt-6 flex flex-col gap-2">
              {platform.downloads.map((dl) => (
                <a
                  href={dl.href}
                  target={dl.external ? '_blank' : undefined}
                  rel={dl.external ? 'noopener noreferrer' : undefined}
                  class={`inline-flex items-center justify-between gap-2 rounded-xl px-4 py-3 text-sm font-semibold transition-colors ${
                    dl.primary
                      ? 'bg-sky-500 text-white hover:bg-sky-400'
                      : 'border border-slate-700 text-slate-300 hover:border-slate-500 hover:text-white'
                  }`}
                >
                  <span>{dl.label}</span>
                  <span class={`text-xs font-normal ${dl.primary ? 'text-sky-100' : 'text-slate-500'}`}>
                    {dl.note}
                  </span>
                </a>
              ))}
            </div>

            <!-- Requirements -->
            <div class="mt-6 border-t border-slate-700/50 pt-4">
              <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-slate-500">Requirements</p>
              <ul class="space-y-1">
                {platform.requirements.map((req) => (
                  <li class="flex items-start gap-2 text-xs text-slate-500">
                    <svg class="h-3.5 w-3.5 mt-0.5 shrink-0 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    {req}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Install instructions -->
  <section class="py-12 sm:py-16 bg-slate-800/20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-10">
        <h2 class="text-2xl font-bold text-white sm:text-3xl">Installing ZyntaPOS</h2>
        <p class="mt-3 text-slate-400">Quick setup on any platform — no technical knowledge required.</p>
      </div>
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
        <!-- Android -->
        <div class="rounded-2xl border border-slate-700/50 bg-slate-800/30 p-6">
          <h3 class="text-base font-semibold text-white mb-4 flex items-center gap-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-sky-500/20 text-xs font-bold text-sky-400">A</span>
            Android Installation
          </h3>
          <ol class="space-y-3">
            {[
              'Download the APK file or install from Google Play',
              'On Android: Settings → Security → Enable "Install from unknown sources" (APK only)',
              'Open the downloaded APK and tap Install',
              'Launch ZyntaPOS and follow the setup wizard',
              'Add your business name, set admin PIN, add first products',
            ].map((step, i) => (
              <li class="flex items-start gap-3 text-sm text-slate-400">
                <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-sky-500/30 bg-sky-500/10 text-xs font-bold text-sky-400">{i + 1}</span>
                {step}
              </li>
            ))}
          </ol>
        </div>
        <!-- Desktop -->
        <div class="rounded-2xl border border-slate-700/50 bg-slate-800/30 p-6">
          <h3 class="text-base font-semibold text-white mb-4 flex items-center gap-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-sky-500/20 text-xs font-bold text-sky-400">D</span>
            Desktop Installation (Windows / macOS / Linux)
          </h3>
          <ol class="space-y-3">
            {[
              'Download the installer for your operating system',
              'Windows: run the .exe installer and follow the wizard',
              'macOS: open the .dmg, drag ZyntaPOS to Applications',
              'Linux: install the .deb package with sudo dpkg -i zyntapos.deb',
              'Launch ZyntaPOS and complete the onboarding wizard',
            ].map((step, i) => (
              <li class="flex items-start gap-3 text-sm text-slate-400">
                <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-sky-500/30 bg-sky-500/10 text-xs font-bold text-sky-400">{i + 1}</span>
                {step}
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Security note -->
  <section class="py-10">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-sky-500/20 bg-sky-500/5 p-6 flex gap-4">
        <svg class="h-6 w-6 shrink-0 text-sky-400 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
        </svg>
        <div>
          <h3 class="text-sm font-semibold text-white">Verified & Safe</h3>
          <p class="mt-1 text-sm text-slate-400">
            All ZyntaPOS downloads are signed and verified. Your local database is encrypted with AES-256 using keys stored in Android Keystore hardware — your data is yours alone.
          </p>
          <a href="/support" class="mt-2 inline-block text-sm font-medium text-sky-400 hover:text-sky-300 transition-colors">
            Read our security overview →
          </a>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner
    title="Questions about installation?"
    subtitle="Check our FAQ or contact support — we reply within 24 hours."
  />
</BaseLayout>
