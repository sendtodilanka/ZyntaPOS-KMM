---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — ZyntaPOS"
  description="The page you're looking for doesn't exist."
  canonical="https://www.zyntapos.com/404"
  noindex={true}
>
  <section class="flex min-h-[70vh] items-center justify-center bg-slate-900 py-24">
    <div class="mx-auto max-w-lg px-4 text-center">
      <div class="mb-8">
        <span class="text-9xl font-extrabold text-slate-800 select-none" aria-hidden="true">404</span>
      </div>
      <div class="relative -mt-16">
        <div class="mb-6 flex justify-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-sky-500/10 text-sky-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
        <h1 class="text-2xl font-bold text-white">Page not found</h1>
        <p class="mt-3 text-slate-400">The page you're looking for doesn't exist or has been moved.</p>
        <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
          <a href="/" class="rounded-xl bg-sky-500 px-6 py-3 text-sm font-semibold text-white hover:bg-sky-400 transition-colors">Go to Homepage</a>
          <a href="/support" class="rounded-xl border border-slate-700 px-6 py-3 text-sm font-semibold text-slate-300 hover:border-slate-500 hover:text-white transition-colors">Visit Support</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
