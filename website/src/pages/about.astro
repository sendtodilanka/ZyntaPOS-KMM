---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import CtaBanner from '@components/CtaBanner.astro';
import { company } from '@data/company';
import { buildBreadcrumbJsonLd } from '@utils/seo';

const canonical = 'https://www.zyntapos.com/about';
const breadcrumbs = [{ name: 'About', url: canonical }];

const techHighlights = [
  { label: 'Language', value: '100% Kotlin (KMP)' },
  { label: 'UI Framework', value: 'Compose Multiplatform' },
  { label: 'Database', value: 'SQLite + SQLCipher AES-256' },
  { label: 'Platforms', value: 'Android + Windows + macOS + Linux' },
  { label: 'Architecture', value: 'Offline-first, Clean Architecture, MVI' },
  { label: 'Security', value: 'Android Keystore, AES-256-GCM, RBAC' },
];

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': ['Organization', 'LocalBusiness'],
  name: company.name,
  url: company.siteUrl,
  logo: `${company.siteUrl}/logo.svg`,
  foundingDate: company.founded,
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'LK',
    addressLocality: 'Sri Lanka',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    email: company.email,
    contactType: 'customer support',
  },
};
---

<BaseLayout
  title="About — ZyntaPOS"
  description="Zynta Solutions Pvt Ltd — building enterprise-grade POS software for Sri Lankan retailers. Founded in Sri Lanka, built with Kotlin Multiplatform."
  canonical={canonical}
  ogImage="/images/og/about.svg"
  jsonLd={[orgJsonLd, buildBreadcrumbJsonLd(breadcrumbs)]}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <section class="bg-slate-900 py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} />
      <div class="mt-8 mx-auto max-w-3xl">
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Built in Sri Lanka,<br />
          <span class="text-sky-400">for the World</span>
        </h1>
        <p class="mt-6 text-lg text-slate-400 leading-relaxed">
          Zynta Solutions was founded with a single mission: make enterprise-grade Point of Sale software
          affordable and accessible for every retailer in Sri Lanka and beyond. We saw small businesses
          struggling with expensive, complicated POS systems that required constant internet connectivity
          — so we built ZyntaPOS.
        </p>
        <p class="mt-4 text-lg text-slate-400 leading-relaxed">
          ZyntaPOS is built with Kotlin Multiplatform — one codebase that runs natively on Android tablets,
          Windows, macOS, and Linux. Every byte of your business data is encrypted with AES-256 and stored
          locally, so you're never dependent on an internet connection to run your business.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-16 bg-slate-800/20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 items-center">
        <div>
          <h2 class="text-3xl font-bold text-white mb-6">Our Mission</h2>
          <p class="text-slate-400 leading-relaxed mb-4">
            We believe every retailer — from a small corner shop to a multi-outlet chain — deserves
            software that's reliable, secure, and affordable. ZyntaPOS brings enterprise features
            to businesses of every size.
          </p>
          <ul class="space-y-3 mt-6">
            {[
              'Offline-first — works without internet, always',
              'Encrypted by default — your data, your control',
              'No vendor lock-in — export your data anytime',
              'Built for Sri Lanka — local tax support, LKR pricing',
            ].map((point) => (
              <li class="flex items-start gap-3 text-slate-300">
                <svg class="h-5 w-5 shrink-0 mt-0.5 text-sky-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {point}
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl border border-slate-700/50 bg-slate-800/50 p-8">
          <h3 class="text-lg font-semibold text-white mb-6">Technology Stack</h3>
          <dl class="space-y-4">
            {techHighlights.map((item) => (
              <div class="flex justify-between items-center border-b border-slate-700/50 pb-3 last:border-b-0 last:pb-0">
                <dt class="text-sm text-slate-400">{item.label}</dt>
                <dd class="text-sm font-medium text-sky-400">{item.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-12">
        <h2 class="text-3xl font-bold text-white">Get in Touch</h2>
        <p class="mt-4 text-slate-400">We'd love to hear from you — whether it's a sales inquiry, support question, or partnership opportunity.</p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-3 max-w-3xl mx-auto">
        {[
          { label: 'General Support', email: company.email, icon: '💬' },
          { label: 'Sales Inquiries', email: company.salesEmail, icon: '📊' },
          { label: 'Company', email: `Company No: ${company.registrationNumber}`, icon: '🏢' },
        ].map((contact) => (
          <div class="rounded-xl border border-slate-700/50 bg-slate-800/50 p-6 text-center">
            <div class="text-3xl mb-3" aria-hidden="true">{contact.icon}</div>
            <h3 class="text-sm font-semibold text-white mb-2">{contact.label}</h3>
            <p class="text-xs text-sky-400">{contact.email}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    title="Ready to try ZyntaPOS?"
    subtitle="Join retailers across Sri Lanka who trust ZyntaPOS to run their business."
  />
</BaseLayout>
