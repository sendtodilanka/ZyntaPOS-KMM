---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import PricingTable from '@components/PricingTable.astro';
import FaqSection from '@components/FaqSection.astro';
import CtaBanner from '@components/CtaBanner.astro';
import { pricingFaq } from '@data/pricing';
import { buildSoftwareApplicationJsonLd, buildBreadcrumbJsonLd, buildFaqJsonLd } from '@utils/seo';

const canonical = 'https://www.zyntapos.com/pricing';
const breadcrumbs = [{ name: 'Pricing', url: canonical }];
---

<BaseLayout
  title="Pricing — ZyntaPOS"
  description="ZyntaPOS pricing: Free Starter, Professional ($29/mo, up to 5 terminals), Enterprise ($79/mo, unlimited stores). 14-day free trial on paid plans."
  canonical={canonical}
  ogImage="/images/og/pricing.svg"
  jsonLd={[
    buildSoftwareApplicationJsonLd(),
    buildBreadcrumbJsonLd(breadcrumbs),
    buildFaqJsonLd(pricingFaq),
  ]}
  breadcrumbs={breadcrumbs}
>
  <!-- Page hero -->
  <section class="bg-slate-900 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} />
      <div class="mt-8 mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Simple, Transparent Pricing
        </h1>
        <p class="mt-6 text-lg text-slate-400">
          Start free. Upgrade when you need more. No hidden fees, no long-term contracts.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing cards -->
  <section id="plans" class="py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <PricingTable preview={false} />
    </div>
  </section>

  <!-- Download anchor -->
  <section id="download" class="py-12 bg-slate-800/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-white mb-4">Download ZyntaPOS</h2>
      <p class="text-slate-400 mb-8">Available for Android tablets (Android 7+) and desktop (Windows, macOS, Linux).</p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="https://play.google.com/store/apps/details?id=com.zyntasolutions.zyntapos"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 rounded-xl border border-slate-600 bg-slate-800 px-6 py-3 text-white hover:border-sky-500 transition-colors"
        >
          <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3.18 23.76a2 2 0 001.07-.32l11.9-6.88-2.57-2.58-10.4 9.78zm-1.06-1.57V1.81L13.27 12 2.12 22.19zM20.3 10.56l-2.68-1.55-2.89 2.89 2.89 2.9 2.7-1.57a1.64 1.64 0 000-2.67zM4.25.56L16.15 7.44 13.58 10 3.18.88A2 2 0 004.25.56z"/>
          </svg>
          <div class="text-left">
            <div class="text-xs text-slate-400">Get it on</div>
            <div class="text-sm font-semibold">Google Play</div>
          </div>
        </a>
        <a
          href="https://github.com/zyntasolutions/ZyntaPOS-KMM/releases"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 rounded-xl border border-slate-600 bg-slate-800 px-6 py-3 text-white hover:border-sky-500 transition-colors"
        >
          <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          <div class="text-left">
            <div class="text-xs text-slate-400">Download for</div>
            <div class="text-sm font-semibold">Windows / macOS / Linux</div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Pricing FAQ -->
  <section id="faq" class="py-16 sm:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Pricing FAQ</h2>
      </div>
      <div class="divide-y divide-slate-700/50 rounded-2xl border border-slate-700/50 bg-slate-800/30 px-6">
        {pricingFaq.map((item, index) => (
          <details class="group border-b border-slate-700/50 last:border-b-0" open={index === 0}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-left font-medium text-slate-200 hover:text-white transition-colors">
              <span>{item.question}</span>
              <svg class="h-5 w-5 shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="pb-5 pr-8 text-sm leading-relaxed text-slate-400">{item.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Enterprise CTA -->
  <CtaBanner
    title="Need a custom plan?"
    subtitle="Contact our sales team for volume pricing, LKR invoicing, or enterprise SLAs."
    primaryLabel="Contact Sales"
    primaryHref="/about#contact"
    secondaryLabel="See All Features"
    secondaryHref="/features"
  />
</BaseLayout>
