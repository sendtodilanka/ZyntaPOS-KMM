---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import FaqAccordion from '@components/FaqAccordion.astro';
import { faqItems } from '@data/faq';
import { company } from '@data/company';
import { buildBreadcrumbJsonLd, buildFaqJsonLd } from '@utils/seo';

const canonical = 'https://www.zyntapos.com/support';
const breadcrumbs = [{ name: 'Support', url: canonical }];

// Group FAQ items by category
const categories = [...new Set(faqItems.map((item) => item.category))];
---

<BaseLayout
  title="POS Software Help & FAQ — Setup, Hardware, Billing | ZyntaPOS Support"
  description="Get help with ZyntaPOS point of sale software. Browse answers about offline setup, hardware compatibility, billing, data security, multi-store configuration, and barcode scanners."
  canonical={canonical}
  jsonLd={[buildBreadcrumbJsonLd(breadcrumbs), buildFaqJsonLd(faqItems)]}
  breadcrumbs={breadcrumbs}
>
  <section class="bg-slate-900 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} />
      <div class="mt-8 mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          How can we help?
        </h1>
        <p class="mt-6 text-lg text-slate-400">
          Browse common questions below or contact our support team directly.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ by category -->
  <section class="py-12 sm:py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 space-y-12">
      {categories.map((category) => {
        const items = faqItems.filter((item) => item.category === category);
        return (
          <div>
            <h2 class="text-xl font-bold text-white mb-6 pb-3 border-b border-slate-700">
              {category}
            </h2>
            <div class="divide-y divide-slate-700/50 rounded-2xl border border-slate-700/50 bg-slate-800/30 px-6">
              {items.map((item, i) => (
                <FaqAccordion question={item.question} answer={item.answer} open={i === 0} />
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Contact section -->
  <section id="community" class="py-16 bg-slate-800/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-white mb-4">Still need help?</h2>
      <p class="text-slate-400 mb-8">Our support team responds within 48 hours (Professional) or 4 hours (Enterprise).</p>
      <a
        href={`mailto:${company.email}`}
        class="inline-flex items-center gap-2 rounded-xl bg-sky-500 px-6 py-3 font-semibold text-white hover:bg-sky-400 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        {company.email}
      </a>
    </div>
  </section>
</BaseLayout>
