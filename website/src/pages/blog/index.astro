---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { buildBreadcrumbJsonLd } from '@utils/seo';

const canonical = 'https://www.zyntapos.com/blog';
const breadcrumbs = [{ name: 'Blog', url: canonical }];
---

<BaseLayout
  title="Blog — ZyntaPOS"
  description="ZyntaPOS blog — tips, updates, and insights for retailers in Sri Lanka."
  canonical={canonical}
  jsonLd={[buildBreadcrumbJsonLd(breadcrumbs)]}
  breadcrumbs={breadcrumbs}
>
  <section class="bg-slate-900 py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} />
      <div class="mt-8 mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl">Blog</h1>
        <p class="mt-6 text-lg text-slate-400">
          Tips, updates, and insights for retailers in Sri Lanka. Coming soon.
        </p>
      </div>
      <!-- Empty state -->
      <div class="mt-16 flex flex-col items-center gap-6 rounded-2xl border border-slate-700/50 bg-slate-800/30 py-20 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
        <div>
          <h2 class="text-xl font-semibold text-white">Coming Soon</h2>
          <p class="mt-2 text-slate-400 max-w-sm">
            We're working on articles about POS best practices, retail tips, and ZyntaPOS updates.
          </p>
        </div>
        <a href="/support" class="text-sm font-medium text-sky-400 hover:text-sky-300 transition-colors">
          View FAQ instead →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
