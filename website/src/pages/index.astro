---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import StatsBar from '@components/StatsBar.astro';
import FeatureSection from '@components/FeatureSection.astro';
import IndustryCard from '@components/IndustryCard.astro';
import PricingTable from '@components/PricingTable.astro';
import FaqSection from '@components/FaqSection.astro';
import CtaBanner from '@components/CtaBanner.astro';
import { homeFeatures } from '@data/features';
import { industries } from '@data/industries';
import { buildOrganizationJsonLd, buildWebSiteJsonLd, buildSoftwareApplicationJsonLd } from '@utils/seo';

const canonical = 'https://www.zyntapos.com/';

const howItWorksSteps = [
  {
    number: '01',
    title: 'Download & Install',
    description: 'Get ZyntaPOS from the Google Play Store or download the desktop installer. No technical setup required.',
  },
  {
    number: '02',
    title: 'Set Up Your Store',
    description: 'Follow the onboarding wizard: add your business name, set up products and categories, configure tax rates.',
  },
  {
    number: '03',
    title: 'Start Selling',
    description: 'Open the register, scan products, accept payments, and print receipts — all offline from day one.',
  },
];
---

<BaseLayout
  title="ZyntaPOS — Free Offline POS System for Retail & Restaurant | Works Without Internet"
  description="ZyntaPOS is a free offline-first point of sale system for retail stores, restaurants, and small businesses. Works without internet, AES-256 encrypted, runs on Android tablets and desktop. No credit card required."
  canonical={canonical}
  ogImage="/images/og/home.svg"
  jsonLd={[buildOrganizationJsonLd(), buildWebSiteJsonLd(), buildSoftwareApplicationJsonLd()]}
>
  <!-- 1. Hero -->
  <Hero />

  <!-- 2. Stats bar -->
  <StatsBar />

  <!-- 3. Key features -->
  <FeatureSection
    id="features"
    title="Everything Your Business Needs"
    subtitle="From offline-first checkout to enterprise audit logging — ZyntaPOS covers it all."
    features={homeFeatures}
    columns={3}
  />

  <!-- 4. How it works -->
  <section class="py-16 sm:py-24 bg-slate-800/20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Up and running in minutes
        </h2>
        <p class="mt-4 text-lg text-slate-400">
          No IT department required. No complicated setup. Just download and sell.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
        {howItWorksSteps.map((step) => (
          <div class="relative flex flex-col items-center text-center gap-4">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl border border-sky-500/30 bg-sky-500/10 text-2xl font-extrabold text-sky-400">
              {step.number}
            </div>
            <h3 class="text-lg font-semibold text-white">{step.title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Industries -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Built for every retail vertical
        </h2>
        <p class="mt-4 text-lg text-slate-400">
          Whether you run a boutique, restaurant, grocery store, or pharmacy — ZyntaPOS adapts to your business.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        {industries.map((industry) => (
          <IndustryCard
            id={industry.id}
            title={industry.title}
            headline={industry.headline}
            description={industry.description}
            icon={industry.icon}
            features={industry.features}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 6. Pricing preview -->
  <section class="py-16 sm:py-24 bg-slate-800/20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Simple, transparent pricing
        </h2>
        <p class="mt-4 text-lg text-slate-400">
          Start free. Scale as you grow. No hidden fees.
        </p>
      </div>
      <PricingTable preview={true} />
    </div>
  </section>

  <!-- 7. FAQ (3 items) -->
  <FaqSection
    title="Common Questions"
    limit={3}
    categories={['Technical', 'Security & Privacy']}
  />

  <!-- 8. CTA -->
  <CtaBanner />
</BaseLayout>
