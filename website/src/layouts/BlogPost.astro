---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { buildBreadcrumbJsonLd } from '@utils/seo';
import { company } from '@data/company';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  author: string;
  image?: string;
  tags: string[];
  slug: string;
}

const { title, description, publishDate, author, image, tags, slug } = Astro.props;

const canonical = `${company.siteUrl}/blog/${slug}`;
const breadcrumbs = [
  { name: 'Blog', url: `${company.siteUrl}/blog` },
  { name: title, url: canonical },
];

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: {
    '@type': 'Organization',
    name: author,
    url: company.siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: company.name,
    logo: {
      '@type': 'ImageObject',
      url: `${company.siteUrl}/logo.svg`,
    },
  },
  datePublished: publishDate.toISOString(),
  dateModified: publishDate.toISOString(),
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  image: image ? `${company.siteUrl}${image}` : `${company.siteUrl}/images/og/blog.svg`,
  keywords: tags.join(', '),
  url: canonical,
  inLanguage: 'en',
};

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogType="article"
  ogImage={image ?? '/images/og/blog.svg'}
  keywords={tags.join(', ')}
  jsonLd={[articleJsonLd, buildBreadcrumbJsonLd(breadcrumbs)]}
  breadcrumbs={breadcrumbs}
>
  <!-- Reading progress bar -->
  <div id="reading-progress" aria-hidden="true"></div>

  <article style="background: var(--th-bg);" class="py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumb -->
      <Breadcrumbs items={breadcrumbs} />

      <!-- ── Article Header (Ghost style) ── -->
      <header class="mt-8">

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="mb-5 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span
                class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-wide"
                style="background: var(--th-code-bg); color: var(--th-link); border: 1px solid var(--th-border-subtle);"
              >
                {tag}
              </span>
            ))}
          </div>
        )}

        <!-- Title -->
        <h1
          class="text-4xl font-extrabold tracking-tight sm:text-5xl leading-tight"
          style="color: var(--th-heading); letter-spacing: -0.02em;"
        >
          {title}
        </h1>

        <!-- Description / deck -->
        <p class="mt-4 text-lg leading-relaxed" style="color: var(--th-text-secondary);">
          {description}
        </p>

        <!-- Meta row — Ghost style -->
        <div
          class="mt-6 flex flex-wrap items-center gap-4 pt-6"
          style="border-top: 1px solid var(--th-border);"
        >
          <!-- Author avatar -->
          <div
            class="h-10 w-10 rounded-full flex items-center justify-center shrink-0"
            style="background: rgba(14, 165, 233, 0.15);"
          >
            <svg class="h-5 w-5 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>

          <div class="flex-1 min-w-0">
            <p class="text-sm font-semibold" style="color: var(--th-heading);">{author}</p>
            <div class="flex items-center gap-2 text-sm" style="color: var(--th-text-muted);">
              <time datetime={publishDate.toISOString()}>{formattedDate}</time>
              <span aria-hidden="true">·</span>
              <span id="reading-time-meta">reading time</span>
            </div>
          </div>

          <!-- Share / bookmark — decorative -->
          <div class="flex items-center gap-2" style="color: var(--th-text-muted);">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
            </svg>
          </div>
        </div>
      </header>

      <!-- Cover image -->
      {image && (
        <div
          class="mt-10 overflow-hidden rounded-2xl"
          style="border: 1px solid var(--th-border);"
        >
          <img src={image} alt={title} class="w-full object-cover" width="800" height="400" loading="eager" />
        </div>
      )}

      <!-- ── Ghost-style divider ── -->
      <div class="mt-10 mb-1 flex items-center gap-4" aria-hidden="true">
        <div class="h-px flex-1" style="background: var(--th-border);"></div>
        <div class="h-1.5 w-1.5 rounded-full" style="background: var(--th-link);"></div>
        <div class="h-px flex-1" style="background: var(--th-border);"></div>
      </div>

      <!-- ── Article Content ── -->
      <div class="mt-8 article-prose">
        <slot />
      </div>

      <!-- ── Ghost-style divider (bottom) ── -->
      <div class="mt-12 mb-10 flex items-center gap-4" aria-hidden="true">
        <div class="h-px flex-1" style="background: var(--th-border);"></div>
        <div class="h-1.5 w-1.5 rounded-full" style="background: var(--th-link);"></div>
        <div class="h-px flex-1" style="background: var(--th-border);"></div>
      </div>

      <!-- ── CTA — Ghost style ── -->
      <div
        class="rounded-2xl p-8 text-center"
        style="background: var(--th-surface); border: 1px solid var(--th-border);"
      >
        <!-- Logo mark -->
        <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-sky-500/10">
          <svg class="h-6 w-6 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h2 class="text-xl font-bold" style="color: var(--th-heading);">Ready to try ZyntaPOS?</h2>
        <p class="mt-2 text-sm leading-relaxed" style="color: var(--th-text-secondary);">
          Free to start. Works fully offline. No credit card, no monthly fees to start.
        </p>
        <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/pricing"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-sky-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-sky-400"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download Free
          </a>
          <a
            href="/features"
            class="inline-flex items-center justify-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold transition-colors"
            style="border: 1px solid var(--th-border); color: var(--th-text);"
          >
            See all features
          </a>
        </div>
      </div>

      <!-- ── Back to blog ── -->
      <div class="mt-10 text-center">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm font-medium transition-colors"
          style="color: var(--th-text-secondary);"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Blog
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  // ── Reading progress bar ──
  const progressBar = document.getElementById('reading-progress');
  const article = document.querySelector('article');

  if (progressBar && article) {
    const update = () => {
      const { top, height } = article.getBoundingClientRect();
      const scrolled = Math.max(0, -top);
      const total = Math.max(1, height - window.innerHeight);
      progressBar.style.width = Math.min(100, (scrolled / total) * 100) + '%';
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  // ── Reading time ──
  const proseEl = document.querySelector('.article-prose');
  const timeEl  = document.getElementById('reading-time-meta');
  if (proseEl && timeEl) {
    const words   = (proseEl.textContent ?? '').trim().split(/\s+/).length;
    const minutes = Math.max(1, Math.ceil(words / 225));
    timeEl.textContent = `${minutes} min read`;
  }
</script>
