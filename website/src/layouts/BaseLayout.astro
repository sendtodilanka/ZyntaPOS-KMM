---
import SeoHead from '@components/SeoHead.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { analytics } from '@data/analytics';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  jsonLd?: object[];
  breadcrumbs?: { name: string; url: string }[];
  keywords?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = '/images/og/home.svg',
  ogType = 'website',
  noindex = false,
  jsonLd = [],
  breadcrumbs = [],
  keywords,
} = Astro.props;

const ga4Id = analytics.GA4_MEASUREMENT_ID;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preload" href="/fonts/inter-latin-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-600.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Theme: apply saved preference BEFORE render to prevent flash -->
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('zynta-theme');
          if (saved === 'light') {
            document.documentElement.classList.add('light');
          }
        } catch (_) {}
      })();
    </script>

    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      jsonLd={jsonLd}
      breadcrumbs={breadcrumbs}
      keywords={keywords}
    />
    {ga4Id && (
      <>
        <!-- Google Analytics 4 -->
        <link rel="preconnect" href="https://www.googletagmanager.com" />
        <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', ga4Id, { anonymize_ip: true });
        </script>
      </>
    )}
  </head>
  <body class="min-h-screen font-sans antialiased">
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
