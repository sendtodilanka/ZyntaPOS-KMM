---
interface Props {
  name: string;
  price: string;
  period?: string;
  description: string;
  features: { text: string; included: boolean; note?: string }[];
  cta: string;
  ctaHref: string;
  popular?: boolean;
  badge?: string;
}

const { name, price, period, description, features, cta, ctaHref, popular = false, badge } = Astro.props;
---

<div class:list={[
  'relative flex flex-col rounded-2xl p-8 transition-transform hover:-translate-y-1',
  popular
    ? 'border-2 border-sky-500 bg-slate-800 shadow-2xl shadow-sky-500/10'
    : 'border border-slate-700 bg-slate-800/50',
]}>
  {badge && (
    <div class="absolute -top-4 left-1/2 -translate-x-1/2">
      <span class="rounded-full bg-sky-500 px-4 py-1 text-xs font-bold uppercase tracking-wider text-white shadow-lg">
        {badge}
      </span>
    </div>
  )}

  <!-- Tier name -->
  <div class="text-xs font-bold uppercase tracking-widest text-sky-400">{name}</div>

  <!-- Price -->
  <div class="mt-4 flex items-baseline gap-1">
    <span class="text-5xl font-extrabold tracking-tight text-white">{price}</span>
    {period && <span class="text-lg text-slate-400">{period}</span>}
  </div>

  <p class="mt-3 text-sm text-slate-400">{description}</p>

  <!-- CTA -->
  <a
    href={ctaHref}
    class:list={[
      'mt-8 block rounded-xl py-3 text-center text-sm font-semibold transition-colors',
      popular
        ? 'bg-sky-500 text-white hover:bg-sky-400'
        : 'border border-slate-600 text-slate-300 hover:border-sky-500 hover:text-white',
    ]}
  >
    {cta}
  </a>

  <!-- Divider -->
  <div class="my-8 border-t border-slate-700"></div>

  <!-- Features list -->
  <ul class="flex flex-col gap-3" role="list">
    {features.map((feature) => (
      <li class="flex items-start gap-3">
        {feature.included ? (
          <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
          </svg>
        ) : (
          <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        )}
        <span class:list={['text-sm', feature.included ? 'text-slate-300' : 'text-slate-600']}>
          {feature.text}
          {feature.note && <span class="ml-1 text-xs text-slate-500">({feature.note})</span>}
        </span>
      </li>
    ))}
  </ul>
</div>
