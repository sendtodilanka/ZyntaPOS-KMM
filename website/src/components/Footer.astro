---
import { footerNav } from '@data/navigation';
import { company } from '@data/company';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-slate-800 bg-slate-900">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Top: Logo + nav columns -->
    <div class="grid grid-cols-2 gap-8 md:grid-cols-5">
      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2" aria-label="ZyntaPOS home">
          <img src="/logomark.svg" alt="" width="32" height="32" />
          <span class="text-lg font-extrabold tracking-tight text-white">
            Zynta<span class="text-sky-400">POS</span>
          </span>
        </a>
        <p class="mt-3 text-sm text-slate-400">
          Offline-first POS for modern retail. Built for the world.
        </p>
        <!-- Social links -->
        <div class="mt-4 flex gap-3">
          {company.linkedin && (
            <a href={company.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-slate-400 hover:text-slate-200 transition-colors">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          )}
          <a href="https://play.google.com/store/apps/details?id=com.zyntasolutions.zyntapos" target="_blank" rel="noopener noreferrer" aria-label="Google Play" class="text-slate-400 hover:text-slate-200 transition-colors">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3.18 23.76a2 2 0 001.07-.32l11.9-6.88-2.57-2.58-10.4 9.78zm-1.06-1.57V1.81L13.27 12 2.12 22.19zM20.3 10.56l-2.68-1.55-2.89 2.89 2.89 2.9 2.7-1.57a1.64 1.64 0 000-2.67zM4.25.56L16.15 7.44 13.58 10 3.18.88A2 2 0 004.25.56z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav columns -->
      {Object.entries(footerNav).map(([category, links]) => (
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-300">{category}</h3>
          <ul class="mt-4 space-y-2" role="list">
            {links.map((link) => (
              <li>
                {link.external ? (
                  <a href={link.href} target="_blank" rel="noopener noreferrer" class="block py-1 text-sm text-slate-400 hover:text-white transition-colors">
                    {link.label}
                  </a>
                ) : (
                  <a href={link.href} class="block py-1 text-sm text-slate-400 hover:text-white transition-colors">
                    {link.label}
                  </a>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-slate-800 pt-8 sm:flex-row">
      <p class="text-sm text-slate-400">
        © {currentYear} {company.name}. All rights reserved.
      </p>
      <p class="text-sm text-slate-400">
        Built with ❤️ for retailers worldwide
      </p>
    </div>
  </div>
</footer>
