---
import { mainNav } from '@data/navigation';

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="sticky top-0 z-50 backdrop-blur-lg"
  style="background: var(--header-bg); border-bottom: 1px solid var(--header-border);"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="ZyntaPOS home">
      <img src="/logomark.svg" alt="" width="36" height="36" />
      <span class="text-xl font-extrabold tracking-tight" style="color: var(--th-heading);">
        Zynta<span class="text-sky-400">POS</span>
      </span>
    </a>

    <!-- Desktop nav — isolated so CTA link outside is not included in nav landmark -->
    <nav aria-label="Main navigation" class="hidden md:block">
      <ul class="flex items-center gap-1" role="list">
        {mainNav.map((link) => {
          const isActive = currentPath === link.href || currentPath.startsWith(link.href + '/');
          return (
            <li>
              <a
                href={link.href}
                class="rounded-md px-3 py-2 text-sm font-medium transition-colors"
                style={isActive
                  ? 'background: var(--nav-active-bg); color: var(--nav-active-text);'
                  : 'color: var(--nav-text);'}
                data-nav-link
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <!-- Right side actions (intentionally outside <nav> to avoid Playwright strict-mode conflicts) -->
    <div class="flex items-center gap-2">
      <!-- Download CTA — links to /download (not /pricing) -->
      <a
        href="/download"
        class="hidden rounded-lg bg-sky-500 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-sky-400 sm:block"
      >
        Download Free
      </a>

      <!-- Dark / Light theme toggle -->
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark/light mode"
        title="Toggle theme"
        class="rounded-md p-2 transition-colors"
        style="color: var(--th-text-secondary);"
      >
        <!-- Sun icon — shown in dark mode -->
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="5" />
          <line x1="12" y1="1" x2="12" y2="3" />
          <line x1="12" y1="21" x2="12" y2="23" />
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
          <line x1="1" y1="12" x2="3" y2="12" />
          <line x1="21" y1="12" x2="23" y2="12" />
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
        </svg>
        <!-- Moon icon — shown in light mode -->
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
        </svg>
      </button>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle menu"
        class="rounded-md p-2 transition-colors md:hidden"
        style="color: var(--th-text-secondary);"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden"
    style="border-top: 1px solid var(--header-border);"
  >
    <ul class="space-y-1 px-4 py-3" role="list">
      {mainNav.map((link) => {
        const isActive = currentPath === link.href;
        return (
          <li>
            <a
              href={link.href}
              class="block rounded-md px-3 py-2 text-base font-medium transition-colors"
              style={isActive
                ? 'background: var(--nav-active-bg); color: var(--nav-active-text);'
                : 'color: var(--nav-text);'}
            >
              {link.label}
            </a>
          </li>
        );
      })}
      <li class="pt-2">
        <!-- Mobile CTA → /download (distinct from Pricing nav link) -->
        <a
          href="/download"
          class="block rounded-lg bg-sky-500 px-3 py-2 text-center text-base font-semibold text-white hover:bg-sky-400 transition-colors"
        >
          Download Free
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // ── Mobile menu ──
  const btn     = document.getElementById('mobile-menu-btn');
  const menu    = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  // ── Theme toggle ──
  const html       = document.documentElement;
  const toggleBtn  = document.getElementById('theme-toggle');
  const sunIcon    = document.getElementById('icon-sun');
  const moonIcon   = document.getElementById('icon-moon');

  function applyTheme(light: boolean) {
    html.classList.toggle('light', light);
    // Sun shown in dark mode (click to switch to light); Moon shown in light mode
    sunIcon?.classList.toggle('hidden', light);
    moonIcon?.classList.toggle('hidden', !light);
    try { localStorage.setItem('zynta-theme', light ? 'light' : 'dark'); } catch (_) {}
  }

  // Initialise icons to match saved / current state
  const isLight = html.classList.contains('light');
  applyTheme(isLight);

  toggleBtn?.addEventListener('click', () => {
    applyTheme(!html.classList.contains('light'));
  });

  // Hover effect for toggle button
  toggleBtn?.addEventListener('mouseenter', () => {
    (toggleBtn as HTMLElement).style.background = 'var(--nav-hover-bg)';
    (toggleBtn as HTMLElement).style.color = 'var(--nav-hover-text)';
  });
  toggleBtn?.addEventListener('mouseleave', () => {
    (toggleBtn as HTMLElement).style.background = '';
    (toggleBtn as HTMLElement).style.color = 'var(--th-text-secondary)';
  });
</script>
