---
interface Props {
  quote: string;
  author: string;
  role: string;
  company: string;
  avatar?: string;
}

const { quote, author, role, company, avatar } = Astro.props;
---

<figure class="flex flex-col gap-6 rounded-2xl border border-slate-700/50 bg-slate-800/50 p-8">
  <!-- Stars -->
  <div class="flex gap-1" aria-label="5 stars">
    {Array.from({ length: 5 }).map(() => (
      <svg class="h-5 w-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  <blockquote class="text-slate-300 leading-relaxed">"{quote}"</blockquote>

  <figcaption class="flex items-center gap-3">
    {avatar ? (
      <img src={avatar} alt={author} class="h-10 w-10 rounded-full object-cover" width="40" height="40" />
    ) : (
      <div class="flex h-10 w-10 items-center justify-center rounded-full bg-sky-500/10 text-sky-400 text-sm font-bold">
        {author.charAt(0)}
      </div>
    )}
    <div>
      <div class="text-sm font-semibold text-white">{author}</div>
      <div class="text-xs text-slate-400">{role} · {company}</div>
    </div>
  </figcaption>
</figure>
