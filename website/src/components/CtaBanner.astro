---
interface Props {
  title?: string;
  subtitle?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  title = 'Ready to modernize your checkout?',
  subtitle = 'Start free — no credit card required. Set up in under 5 minutes.',
  primaryLabel = 'Download Free',
  primaryHref = '/download',
  secondaryLabel = 'See Pricing',
  secondaryHref = '/pricing',
} = Astro.props;
---

<section class="py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-3xl bg-sky-600 px-8 py-14 text-center shadow-2xl shadow-sky-900/30 sm:px-16">
      <!-- Background decoration -->
      <div class="absolute inset-0 -z-10" aria-hidden="true">
        <div class="absolute -left-20 -top-20 h-64 w-64 rounded-full bg-white/5"></div>
        <div class="absolute -right-20 -bottom-20 h-64 w-64 rounded-full bg-white/5"></div>
      </div>

      <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        {title}
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-sky-100">
        {subtitle}
      </p>
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href={primaryHref}
          class="inline-flex items-center gap-2 rounded-xl bg-white px-8 py-3.5 text-base font-bold text-sky-600 shadow-lg transition-all hover:bg-sky-50"
        >
          {primaryLabel}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        {secondaryLabel !== primaryLabel && (
          <a
            href={secondaryHref}
            class="inline-flex items-center gap-2 rounded-xl border border-white/30 px-8 py-3.5 text-base font-semibold text-white transition-colors hover:border-white/60 hover:bg-white/10"
          >
            {secondaryLabel}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
