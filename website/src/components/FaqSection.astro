---
import FaqAccordion from './FaqAccordion.astro';
import { faqItems } from '@data/faq';

interface Props {
  title?: string;
  subtitle?: string;
  limit?: number;
  categories?: string[];
  jsonLd?: boolean;
}

const {
  title = 'Frequently Asked Questions',
  subtitle,
  limit,
  categories,
  jsonLd = true,
} = Astro.props;

const filtered = categories
  ? faqItems.filter((item) => categories.includes(item.category))
  : faqItems;

const displayed = limit ? filtered.slice(0, limit) : filtered;

// Build JSON-LD for FAQ
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: displayed.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<section class="py-16 sm:py-24">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="mb-10 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{title}</h2>
      {subtitle && <p class="mt-4 text-lg text-slate-400">{subtitle}</p>}
    </div>

    <div class="divide-y divide-slate-700/50 rounded-2xl border border-slate-700/50 bg-slate-800/30 px-6">
      {displayed.map((item, index) => (
        <FaqAccordion
          question={item.question}
          answer={item.answer}
          open={index === 0}
        />
      ))}
    </div>
  </div>
</section>

{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}
