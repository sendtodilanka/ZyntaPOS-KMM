---
const stats = [
  { value: '100+', label: 'Retailers Worldwide' },
  { value: '99.9%', label: 'Offline Uptime' },
  { value: 'AES-256', label: 'Encryption Standard' },
  { value: '5 min', label: 'Average Setup Time' },
];
---

<section class="border-y border-slate-800 bg-slate-800/30 py-10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4">
      {stats.map((stat) => (
        <div class="text-center">
          <dt class="text-3xl font-extrabold text-sky-400">{stat.value}</dt>
          <dd class="mt-1 text-sm text-slate-400">{stat.label}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
