---
interface Props {
  id: string;
  title: string;
  headline: string;
  description: string;
  icon: string;
  features: string[];
}

const { id, title, headline, description, icon, features } = Astro.props;
---

<article class="group flex flex-col gap-5 rounded-2xl border border-slate-700/50 bg-slate-800/50 p-8 transition-colors hover:border-sky-500/30 hover:bg-slate-800">
  <!-- Icon + title -->
  <div class="flex items-center gap-3">
    <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-sky-500/10 text-sky-400">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016 2.993 2.993 0 002.25-1.016 3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 2.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .415.336.75.75.75z" />
      </svg>
    </div>
    <div>
      <p class="text-xs font-medium uppercase tracking-wider text-sky-400">{title}</p>
      <h2 class="text-lg font-bold text-white">{headline}</h2>
    </div>
  </div>

  <p class="text-sm text-slate-400 leading-relaxed">{description}</p>

  <ul class="grid grid-cols-1 gap-2 sm:grid-cols-2" role="list">
    {features.map((feature) => (
      <li class="flex items-center gap-2 text-sm text-slate-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
        {feature}
      </li>
    ))}
  </ul>

  <a
    href={`/industries#${id}`}
    class="mt-auto inline-flex items-center gap-1 text-sm font-medium text-sky-400 hover:text-sky-300 transition-colors"
  >
    Learn more about {title} POS
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </a>
</article>
