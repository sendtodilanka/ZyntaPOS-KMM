---
interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
}

const { icon, title, description, href } = Astro.props;

// Extract icon name from "lucide:icon-name" format for inline SVG fallback
const iconName = icon.split(':')[1] ?? icon;
---

<div class="group relative flex flex-col gap-4 rounded-xl border border-slate-700/50 bg-slate-800/50 p-6 transition-colors hover:border-sky-500/30 hover:bg-slate-800">
  <!-- Icon container -->
  <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-sky-500/10 text-sky-400">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <!-- Generic icon placeholder — astro-icon will replace this in production -->
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
  </div>

  <!-- Content -->
  <div>
    <h3 class="text-base font-semibold text-white">{title}</h3>
    <p class="mt-2 text-sm text-slate-400 leading-relaxed">{description}</p>
  </div>

  {href && (
    <a href={href} class="absolute inset-0 rounded-xl" aria-label={`Learn more about ${title}`}>
      <span class="sr-only">Learn more about {title}</span>
    </a>
  )}
</div>
