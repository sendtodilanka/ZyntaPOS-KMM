# ═══════════════════════════════════════════════════════════════════
# ZyntaPOS — Caddyfile (Production)
#
# All 6 subdomains use the Cloudflare Origin Certificate for TLS.
# Cloudflare (orange-cloud) terminates public TLS; Caddy handles
# the origin leg with the wildcard CF cert.
#
# Generate the Cloudflare Origin Certificate at:
#   Cloudflare → SSL/TLS → Origin Server → Create Certificate
#   Hostnames: zyntapos.com, *.zyntapos.com
#   Upload to VPS: /etc/caddy/certs/zyntapos_origin.{pem,key}
#
# TODO-007 migration status:
#   api.zyntapos.com      → api:8080     ✅ real service
#   license.zyntapos.com  → license:8083 ✅ real service
#   sync.zyntapos.com     → sync:8082    ✅ real service
#   zyntapos.com          → website:80   ✅ Astro static site (Docker image from GHCR)
#   www.zyntapos.com      → website:80   ✅ Astro static site (Docker image from GHCR)
#   panel.zyntapos.com    → admin-panel:3000 ✅ React admin panel
#   docs.zyntapos.com     → canary:80    🔲 Phase 3
#   status.zyntapos.com   → canary:80    🔲 Phase 3
# ═══════════════════════════════════════════════════════════════════

# Shared TLS block — Cloudflare Origin Certificate (wildcard *.zyntapos.com)
(cf_tls) {
	tls /etc/caddy/certs/zyntapos_origin.pem /etc/caddy/certs/zyntapos_origin.key
}

# ── Healthcheck (localhost only — Docker healthcheck probe) ──────────
# Also routes /health to backend services for smoke tests (SSH via localhost).
# Named virtual hosts with TLS only bind to port 443, so the smoke test
# hits http://localhost/health with Host: header — which matches here.
:80 {
	respond /ping 200 {
		body "ok"
		close
	}

	# Route /health to api backend (used by smoke test & Docker healthcheck)
	@api_health {
		host api.zyntapos.com
		path /health /health/*
	}
	handle @api_health {
		reverse_proxy api:8080
	}

	# Route /health to license backend
	@license_health {
		host license.zyntapos.com
		path /health /health/*
	}
	handle @license_health {
		reverse_proxy license:8083
	}

	# Route /health to sync backend
	@sync_health {
		host sync.zyntapos.com
		path /health /health/*
	}
	handle @sync_health {
		reverse_proxy sync:8082
	}

	# All other requests on port 80 without a matching Host/path get 404
	respond 404
}

# ── zyntapos.com / www — Marketing website (Astro static site) ────────────
zyntapos.com, www.zyntapos.com {
	import cf_tls
	reverse_proxy website:80 {
		health_uri /ping
		health_interval 30s
		health_timeout 10s
	}
}

# ── api.zyntapos.com — REST API (Ktor) ────────────────────────────
api.zyntapos.com {
	import cf_tls

	# Strip sensitive response headers from upstream
	header -X-Powered-By

	# Browser visiting root → show branded canary page
	@browser_root {
		path /
		header Accept *text/html*
	}
	handle @browser_root {
		reverse_proxy canary:80
	}

	# All API requests → real service
	handle {
		reverse_proxy api:8080 {
			# Pass real client IP through Cloudflare proxy
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			# Liveness check only — DB issues won't block all traffic
			health_uri /ping
			health_interval 30s
			health_timeout 10s
		}
	}
}

# ── license.zyntapos.com — License server (Ktor) ──────────────────
license.zyntapos.com {
	import cf_tls

	# Browser visiting root → show branded canary page
	@browser_root {
		path /
		header Accept *text/html*
	}
	handle @browser_root {
		reverse_proxy canary:80
	}

	# All API requests → real service
	handle {
		reverse_proxy license:8083 {
			header_up X-Real-IP {remote_host}
			health_uri /ping
			health_interval 30s
			health_timeout 10s
		}
	}
}

# ── sync.zyntapos.com — WebSocket sync engine ─────────────────────
sync.zyntapos.com {
	import cf_tls

	# Browser visiting root → show branded canary page
	@browser_root {
		path /
		header Accept *text/html*
	}
	handle @browser_root {
		reverse_proxy canary:80
	}

	# All API/WebSocket requests → real service
	handle {
		reverse_proxy sync:8082 {
			# Pass real client IP through Cloudflare proxy
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			# WebSocket connections — pass Upgrade header
			header_up Connection {>Connection}
			header_up Upgrade {>Upgrade}
			health_uri /ping
			health_interval 30s
			health_timeout 10s
		}
	}
}

# ── panel.zyntapos.com — Admin dashboard (React SPA) ─────────────
panel.zyntapos.com {
	import cf_tls

	# SPA fallback — serve index.html for all non-asset routes
	# so TanStack Router can handle client-side navigation
	@assets {
		path /assets/* /favicon.ico /robots.txt
	}
	handle @assets {
		reverse_proxy admin-panel:3000
	}
	handle {
		reverse_proxy admin-panel:3000
	}
}

# ── docs.zyntapos.com — Documentation site (Phase 3) ──────────────
docs.zyntapos.com {
	import cf_tls
	reverse_proxy canary:80
}

# ── status.zyntapos.com — Uptime status page (Uptime Kuma) ─────────
status.zyntapos.com {
	import cf_tls
	reverse_proxy uptime-kuma:3001
}
