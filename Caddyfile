# ═══════════════════════════════════════════════════════════════════
# ZyntaPOS — Caddyfile (Production)
#
# All 6 subdomains use the Cloudflare Origin Certificate for TLS.
# Cloudflare (orange-cloud) terminates public TLS; Caddy handles
# the origin leg with the wildcard CF cert.
#
# Generate the Cloudflare Origin Certificate at:
#   Cloudflare → SSL/TLS → Origin Server → Create Certificate
#   Hostnames: zyntapos.com, *.zyntapos.com
#   Upload to VPS: /etc/caddy/certs/zyntapos_origin.{pem,key}
#
# TODO-007 migration status:
#   api.zyntapos.com      → api:8080     ✅ real service
#   license.zyntapos.com  → license:8083 ✅ real service
#   sync.zyntapos.com     → sync:8082    ✅ real service
#   panel.zyntapos.com    → canary:80    🔲 Phase 3 (React panel)
#   docs.zyntapos.com     → canary:80    🔲 Phase 3
#   status.zyntapos.com   → canary:80    🔲 Phase 3
# ═══════════════════════════════════════════════════════════════════

# Shared TLS block — Cloudflare Origin Certificate (wildcard *.zyntapos.com)
(cf_tls) {
	tls /etc/caddy/certs/zyntapos_origin.pem /etc/caddy/certs/zyntapos_origin.key
}

# ── Healthcheck (localhost only — Docker healthcheck probe) ──────────
:80 {
	respond /ping 200 {
		body "ok"
		close
	}

	# All other requests on port 80 without a matching Host get 404
	respond 404
}

# ── api.zyntapos.com — REST API (Ktor) ────────────────────────────
api.zyntapos.com {
	import cf_tls

	# Strip sensitive response headers from upstream
	header -X-Powered-By

	# Browser visiting root → show branded canary page
	@browser_root {
		path /
		header Accept *text/html*
	}
	handle @browser_root {
		reverse_proxy canary:80
	}

	# All API requests → real service
	handle {
		reverse_proxy api:8080 {
			# Pass real client IP through Cloudflare proxy
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			# Liveness check only — DB issues won't block all traffic
			health_uri /ping
			health_interval 30s
			health_timeout 10s
		}
	}
}

# ── license.zyntapos.com — License server (Ktor) ──────────────────
license.zyntapos.com {
	import cf_tls

	# Browser visiting root → show branded canary page
	@browser_root {
		path /
		header Accept *text/html*
	}
	handle @browser_root {
		reverse_proxy canary:80
	}

	# All API requests → real service
	handle {
		reverse_proxy license:8083 {
			header_up X-Real-IP {remote_host}
			health_uri /ping
			health_interval 30s
			health_timeout 10s
		}
	}
}

# ── sync.zyntapos.com — WebSocket sync engine ─────────────────────
sync.zyntapos.com {
	import cf_tls

	# Browser visiting root → show branded canary page
	@browser_root {
		path /
		header Accept *text/html*
	}
	handle @browser_root {
		reverse_proxy canary:80
	}

	# All API/WebSocket requests → real service
	handle {
		reverse_proxy sync:8082 {
			# Pass real client IP through Cloudflare proxy
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			# WebSocket connections — pass Upgrade header
			header_up Connection {>Connection}
			header_up Upgrade {>Upgrade}
			health_uri /ping
			health_interval 30s
			health_timeout 10s
		}
	}
}

# ── panel.zyntapos.com — Admin dashboard (Phase 3) ────────────────
panel.zyntapos.com {
	import cf_tls
	reverse_proxy canary:80
}

# ── docs.zyntapos.com — Documentation site (Phase 3) ──────────────
docs.zyntapos.com {
	import cf_tls
	reverse_proxy canary:80
}

# ── status.zyntapos.com — Uptime status page (Phase 3) ────────────
status.zyntapos.com {
	import cf_tls
	reverse_proxy canary:80
}
