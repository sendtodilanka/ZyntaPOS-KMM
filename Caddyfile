# ═══════════════════════════════════════════════════════════════════
# ZyntaPOS — Caddyfile (Production)
#
# All 6 subdomains use the Cloudflare Origin Certificate for TLS.
# Cloudflare (orange-cloud) terminates public TLS; Caddy handles
# the origin leg with the wildcard CF cert.
#
# Generate the Cloudflare Origin Certificate at:
#   Cloudflare → SSL/TLS → Origin Server → Create Certificate
#   Hostnames: zyntapos.com, *.zyntapos.com
#   Upload to VPS: /etc/caddy/certs/zyntapos_origin.{pem,key}
#
# TODO-007 migration status:
#   api.zyntapos.com      → api:8080     ✅ real service
#   license.zyntapos.com  → license:8083 ✅ real service
#   sync.zyntapos.com     → sync:8082    ✅ real service
#   zyntapos.com          → website:80   ✅ Astro static site (Docker image from GHCR)
#   www.zyntapos.com      → website:80   ✅ Astro static site (Docker image from GHCR)
#   panel.zyntapos.com    → admin-panel:3000 ✅ React admin panel
#   docs.zyntapos.com     → docs:3001    ✅ Scalar OpenAPI docs
#   status.zyntapos.com   → uptime-kuma:3001 ✅ Uptime Kuma
#   webmail.zyntapos.com  → roundcube:80     ✅ Roundcube webmail
# ═══════════════════════════════════════════════════════════════════

# Shared TLS block — Cloudflare Origin Certificate (wildcard *.zyntapos.com)
(cf_tls) {
	tls /etc/caddy/certs/zyntapos_origin.pem /etc/caddy/certs/zyntapos_origin.key
}

# ── Healthcheck (localhost only — Docker healthcheck probe) ──────────
# /ping is the canonical liveness probe used by Docker healthcheck and
# the smoke test.  Host-matched /health routes were removed because
# Caddy silently drops them: when named HTTPS blocks (api.zyntapos.com,
# etc.) own a hostname, the :80 catch-all block's host matchers for
# those names are not included in the adapted config.  The smoke test
# now calls /health directly on backend containers via docker compose exec.
#
# /.well-known/acme-challenge/* — served from bind-mounted webroot for
# ACME HTTP-01 cert renewal (mail.zyntapos.com).  cert-renew-mail.yml
# uses acme.sh --webroot mode which writes challenge files to
# backend/caddy/acme-challenges/ on the VPS host (mapped to
# /etc/caddy/acme-challenges/ in this container).
# mail.zyntapos.com is grey-cloud (DNS-only) so LE can reach port 80 directly.
:80 {
	respond /ping 200 {
		body "ok"
		close
	}

	# ACME HTTP-01 challenge webroot for mail.zyntapos.com cert renewal
	handle /.well-known/acme-challenge/* {
		root * /etc/caddy/acme-challenges
		file_server
	}

	# All other requests on port 80 get 404
	respond 404
}

# ── zyntapos.com / www — Marketing website (Astro static site) ────────────
zyntapos.com, www.zyntapos.com {
	import cf_tls
	reverse_proxy website:80 {
		health_uri /ping
		health_interval 30s
		health_timeout 10s
	}
}

# ── api.zyntapos.com — REST API (Ktor) ────────────────────────────
api.zyntapos.com {
	import cf_tls

	# Strip sensitive response headers from upstream
	header -X-Powered-By

	# /health and /ping — proxy to backend for smoke tests & monitoring
	@health_or_ping {
		path /health /health/* /ping
	}
	handle @health_or_ping {
		reverse_proxy api:8080
	}

	# Browser visiting root → show branded canary page
	@browser_root {
		path /
		header Accept *text/html*
	}
	handle @browser_root {
		reverse_proxy canary:80
	}

	# All API requests → real service
	handle {
		reverse_proxy api:8080 {
			# Pass real client IP through Cloudflare proxy
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			# Liveness check only — DB issues won't block all traffic
			health_uri /ping
			health_interval 30s
			health_timeout 10s
		}
	}
}

# ── license.zyntapos.com — License server (Ktor) ──────────────────
license.zyntapos.com {
	import cf_tls

	# /health and /ping — proxy to backend for smoke tests & monitoring
	@health_or_ping {
		path /health /health/* /ping
	}
	handle @health_or_ping {
		reverse_proxy license:8083
	}

	# Browser visiting root → show branded canary page
	@browser_root {
		path /
		header Accept *text/html*
	}
	handle @browser_root {
		reverse_proxy canary:80
	}

	# All API requests → real service
	handle {
		reverse_proxy license:8083 {
			header_up X-Real-IP {remote_host}
			health_uri /ping
			health_interval 30s
			health_timeout 10s
		}
	}
}

# ── sync.zyntapos.com — WebSocket sync engine ─────────────────────
sync.zyntapos.com {
	import cf_tls

	# /health and /ping — proxy to backend for smoke tests & monitoring
	@health_or_ping {
		path /health /health/* /ping
	}
	handle @health_or_ping {
		reverse_proxy sync:8082
	}

	# Browser visiting root → show branded canary page
	@browser_root {
		path /
		header Accept *text/html*
	}
	handle @browser_root {
		reverse_proxy canary:80
	}

	# All API/WebSocket requests → real service
	handle {
		reverse_proxy sync:8082 {
			# Pass real client IP through Cloudflare proxy
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			# WebSocket connections — pass Upgrade header
			header_up Connection {>Connection}
			header_up Upgrade {>Upgrade}
			health_uri /ping
			health_interval 30s
			health_timeout 10s
		}
	}
}

# ── panel.zyntapos.com — Admin dashboard (React SPA) ─────────────
panel.zyntapos.com {
	import cf_tls

	# SPA fallback — serve index.html for all non-asset routes
	# so TanStack Router can handle client-side navigation
	@assets {
		path /assets/* /favicon.ico /robots.txt
	}
	handle @assets {
		reverse_proxy admin-panel:3000
	}
	handle {
		reverse_proxy admin-panel:3000
	}
}

# ── docs.zyntapos.com — API Documentation (Scalar OpenAPI viewer) ──
docs.zyntapos.com {
	import cf_tls
	reverse_proxy docs:3001
}

# ── status.zyntapos.com — Uptime status page (Uptime Kuma) ─────────
status.zyntapos.com {
	import cf_tls
	reverse_proxy uptime-kuma:3001
}

# ── mail.zyntapos.com — Stalwart Mail Server admin console (TODO-008a) ─────
# JMAP API + admin UI. Protected by Stalwart's own auth (admin password).
# Staff mailboxes: configured here by admin after first deploy.
#
# NOTE: Does NOT use cf_tls (Cloudflare Origin Cert).
# mail.zyntapos.com MUST be grey-cloud (DNS-only) in Cloudflare so that
# IMAP (993), SMTP (587/465/25) ports reach the VPS directly.
#
# TLS: Uses an explicit Let's Encrypt cert obtained externally via DNS-01
# (cert-renew-mail.yml GitHub Actions workflow using acme.sh + Cloudflare API).
# Caddy's built-in ACME cannot be used here because the *.zyntapos.com
# Cloudflare Origin Certificate loaded by other site blocks is in Caddy's
# shared cert cache, causing Caddy to skip ACME automation for this domain.
# The cert is placed at /etc/caddy/certs/ by the renewal workflow and must
# exist on the VPS before Caddy is (re)started. Run cert-renew-mail.yml
# manually after first deploy to issue the initial certificate.
mail.zyntapos.com {
	tls /etc/caddy/certs/mail.zyntapos.com.pem /etc/caddy/certs/mail.zyntapos.com.key

	# Compress WASM + JS assets — the admin UI WASM binary is ~6.7 MB
	# uncompressed, causing HTTP/2 stream resets on slow connections.
	encode zstd gzip

	reverse_proxy stalwart:8080 {
		# Stalwart redirects /.well-known/jmap → admin UI (307), which Caddy
		# treats as unhealthy. Use root path instead — returns 200 (admin HTML).
		health_uri /
		health_interval 30s
		health_timeout 10s
		# Buffer full response before sending to client — prevents HTTP/2
		# stream closures on large WASM transfers (TODO-008a fix).
		flush_interval -1
	}
}

# ── webmail.zyntapos.com — Roundcube webmail (staff browser-based email) ─────
# Provides browser-based IMAP/SMTP access to @zyntapos.com mailboxes via Stalwart.
# Uses the wildcard Cloudflare Origin Certificate (cf_tls) — no separate cert needed.
# DNS: webmail.zyntapos.com → VPS IP, orange-cloud (Cloudflare proxied).
# Contrast with mail.zyntapos.com which is grey-cloud (needs direct IMAP/SMTP TCP).
webmail.zyntapos.com {
	import cf_tls

	# Compress assets — Roundcube elastic skin ships ~2 MB of CSS/JS
	# NOTE: encode must NOT be combined with flush_interval -1 (streaming mode).
	# Roundcube sends standard buffered HTML responses, so default Caddy
	# buffering is correct and encode works as expected.
	encode zstd gzip

	reverse_proxy roundcube:80 {
		# Pass real client IP through Cloudflare proxy
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		# Root path returns 200 login page — safe health URI
		health_uri /
		health_interval 30s
		health_timeout 10s
	}
}

# ── support.zyntapos.com — Chatwoot customer support inbox (TODO-008a) ───────
# HELPDESK agents use this to see and respond to support tickets created
# from inbound emails (support@, billing@, bugs@).
support.zyntapos.com {
	import cf_tls
	reverse_proxy chatwoot-web:3000 {
		health_interval 30s
		health_timeout 10s
	}
}
