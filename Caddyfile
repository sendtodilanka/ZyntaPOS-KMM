# ═══════════════════════════════════════════════════════════════════
# ZyntaPOS — Caddyfile
#
# All 6 subdomains use the Cloudflare Origin Certificate for TLS.
# Cloudflare terminates public TLS (orange-cloud); Caddy handles
# the origin leg with the wildcard CF cert.
#
# Why not Let's Encrypt for sync? The VPS firewall restricts ports
# 80/443 to Cloudflare IP ranges — ACME HTTP-01 challenge cannot
# reach the VPS from Let's Encrypt servers. CF Origin cert is used
# for all subdomains including sync.
#
# NOTE (Phase 3): When the real WebSocket sync engine is deployed,
# sync.zyntapos.com should remain orange-cloud. Cloudflare proxies
# WebSocket connections on the free plan.
#
# Phase 2 canary: all subdomains proxy to the `canary` nginx container.
# When real services are deployed, replace `canary:80` with the
# service container name and port for each subdomain.
# ═══════════════════════════════════════════════════════════════════

# Shared TLS block — Cloudflare Origin Certificate (wildcard *.zyntapos.com)
(cf_tls) {
	tls /etc/caddy/certs/zyntapos_origin.pem /etc/caddy/certs/zyntapos_origin.key
}

# ── api.zyntapos.com — REST API (Ktor, Phase 2) ───────────────────
api.zyntapos.com {
	import cf_tls
	reverse_proxy canary:80
}

# ── license.zyntapos.com — License server (Ktor, Phase 2) ──────────
license.zyntapos.com {
	import cf_tls
	reverse_proxy canary:80
}

# ── panel.zyntapos.com — Internal admin dashboard (Phase 3) ────────
panel.zyntapos.com {
	import cf_tls
	reverse_proxy canary:80
}

# ── docs.zyntapos.com — Documentation site (Phase 2) ───────────────
docs.zyntapos.com {
	import cf_tls
	reverse_proxy canary:80
}

# ── status.zyntapos.com — Uptime / status page (Phase 2) ───────────
status.zyntapos.com {
	import cf_tls
	reverse_proxy canary:80
}

# ── sync.zyntapos.com — WebSocket sync engine (orange-cloud) ───────
sync.zyntapos.com {
	import cf_tls
	reverse_proxy canary:80
}
