# ═══════════════════════════════════════════════════════════════════
# ZyntaPOS — Caddyfile (Production)
#
# All 6 subdomains use the Cloudflare Origin Certificate for TLS.
# Cloudflare (orange-cloud) terminates public TLS; Caddy handles
# the origin leg with the wildcard CF cert.
#
# Generate the Cloudflare Origin Certificate at:
#   Cloudflare → SSL/TLS → Origin Server → Create Certificate
#   Hostnames: zyntapos.com, *.zyntapos.com
#   Upload to VPS: /etc/caddy/certs/zyntapos_origin.{pem,key}
#
# TODO-007 migration status:
#   api.zyntapos.com      → api:8080     ✅ real service
#   license.zyntapos.com  → license:8083 ✅ real service
#   sync.zyntapos.com     → sync:8082    ✅ real service
#   zyntapos.com          → website:80   ✅ Astro static site (Docker image from GHCR)
#   www.zyntapos.com      → website:80   ✅ Astro static site (Docker image from GHCR)
#   panel.zyntapos.com    → admin-panel:3000 ✅ React admin panel
#   docs.zyntapos.com     → docs:3001    ✅ Scalar OpenAPI docs
#   status.zyntapos.com   → uptime-kuma:3001 ✅ Uptime Kuma
# ═══════════════════════════════════════════════════════════════════

# Shared TLS block — Cloudflare Origin Certificate (wildcard *.zyntapos.com)
(cf_tls) {
	tls /etc/caddy/certs/zyntapos_origin.pem /etc/caddy/certs/zyntapos_origin.key
}

# ── Healthcheck (localhost only — Docker healthcheck probe) ──────────
# /ping is the canonical liveness probe used by Docker healthcheck and
# the smoke test.  Host-matched /health routes were removed because
# Caddy silently drops them: when named HTTPS blocks (api.zyntapos.com,
# etc.) own a hostname, the :80 catch-all block's host matchers for
# those names are not included in the adapted config.  The smoke test
# now calls /health directly on backend containers via docker compose exec.
#
# NOTE: Caddy handles ACME HTTP-01 challenges for mail.zyntapos.com
# internally before this :80 catch-all is reached. This block does NOT
# interfere with Let's Encrypt cert provisioning for grey-cloud domains.
:80 {
	respond /ping 200 {
		body "ok"
		close
	}

	# All other requests on port 80 get 404
	respond 404
}

# ── zyntapos.com / www — Marketing website (Astro static site) ────────────
zyntapos.com, www.zyntapos.com {
	import cf_tls
	reverse_proxy website:80 {
		health_uri /ping
		health_interval 30s
		health_timeout 10s
	}
}

# ── api.zyntapos.com — REST API (Ktor) ────────────────────────────
api.zyntapos.com {
	import cf_tls

	# Strip sensitive response headers from upstream
	header -X-Powered-By

	# /health and /ping — proxy to backend for smoke tests & monitoring
	@health_or_ping {
		path /health /health/* /ping
	}
	handle @health_or_ping {
		reverse_proxy api:8080
	}

	# Browser visiting root → show branded canary page
	@browser_root {
		path /
		header Accept *text/html*
	}
	handle @browser_root {
		reverse_proxy canary:80
	}

	# All API requests → real service
	handle {
		reverse_proxy api:8080 {
			# Pass real client IP through Cloudflare proxy
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			# Liveness check only — DB issues won't block all traffic
			health_uri /ping
			health_interval 30s
			health_timeout 10s
		}
	}
}

# ── license.zyntapos.com — License server (Ktor) ──────────────────
license.zyntapos.com {
	import cf_tls

	# /health and /ping — proxy to backend for smoke tests & monitoring
	@health_or_ping {
		path /health /health/* /ping
	}
	handle @health_or_ping {
		reverse_proxy license:8083
	}

	# Browser visiting root → show branded canary page
	@browser_root {
		path /
		header Accept *text/html*
	}
	handle @browser_root {
		reverse_proxy canary:80
	}

	# All API requests → real service
	handle {
		reverse_proxy license:8083 {
			header_up X-Real-IP {remote_host}
			health_uri /ping
			health_interval 30s
			health_timeout 10s
		}
	}
}

# ── sync.zyntapos.com — WebSocket sync engine ─────────────────────
sync.zyntapos.com {
	import cf_tls

	# /health and /ping — proxy to backend for smoke tests & monitoring
	@health_or_ping {
		path /health /health/* /ping
	}
	handle @health_or_ping {
		reverse_proxy sync:8082
	}

	# Browser visiting root → show branded canary page
	@browser_root {
		path /
		header Accept *text/html*
	}
	handle @browser_root {
		reverse_proxy canary:80
	}

	# All API/WebSocket requests → real service
	handle {
		reverse_proxy sync:8082 {
			# Pass real client IP through Cloudflare proxy
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			# WebSocket connections — pass Upgrade header
			header_up Connection {>Connection}
			header_up Upgrade {>Upgrade}
			health_uri /ping
			health_interval 30s
			health_timeout 10s
		}
	}
}

# ── panel.zyntapos.com — Admin dashboard (React SPA) ─────────────
panel.zyntapos.com {
	import cf_tls

	# SPA fallback — serve index.html for all non-asset routes
	# so TanStack Router can handle client-side navigation
	@assets {
		path /assets/* /favicon.ico /robots.txt
	}
	handle @assets {
		reverse_proxy admin-panel:3000
	}
	handle {
		reverse_proxy admin-panel:3000
	}
}

# ── docs.zyntapos.com — API Documentation (Scalar OpenAPI viewer) ──
docs.zyntapos.com {
	import cf_tls
	reverse_proxy docs:3001
}

# ── status.zyntapos.com — Uptime status page (Uptime Kuma) ─────────
status.zyntapos.com {
	import cf_tls
	reverse_proxy uptime-kuma:3001
}

# ── mail.zyntapos.com — Stalwart Mail Server admin console (TODO-008a) ─────
# JMAP API + admin UI. Protected by Stalwart's own auth (admin password).
# Staff mailboxes: configured here by admin after first deploy.
#
# NOTE: Does NOT use cf_tls (Cloudflare Origin Cert).
# mail.zyntapos.com MUST be grey-cloud (DNS-only) in Cloudflare so that
# IMAP (993), SMTP (587/465/25) ports reach the VPS directly.
# Caddy auto-provisions a Let's Encrypt cert for this domain instead.
mail.zyntapos.com {
	reverse_proxy stalwart:8080 {
		health_uri /.well-known/jmap
		health_interval 30s
		health_timeout 10s
	}
}

# ── support.zyntapos.com — Chatwoot customer support inbox (TODO-008a) ───────
# HELPDESK agents use this to see and respond to support tickets created
# from inbound emails (support@, billing@, bugs@).
support.zyntapos.com {
	import cf_tls
	reverse_proxy chatwoot-web:3000 {
		health_interval 30s
		health_timeout 10s
	}
}
