# ═══════════════════════════════════════════════════════════════════
# ZyntaPOS — .gitignore
# ═══════════════════════════════════════════════════════════════════

# ── Secrets & Local Config (NEVER commit) ───────────────────────────
local.properties
*.jks
*.keystore
*.p12
*.pfx

# ── TLS Certificates (stored on VPS host, never in repo) ─────────────
certs/

# ── Gradle Internals ────────────────────────────────────────────────
.gradle/
**/build/
!src/**/build/
gradle-wrapper.jar
.kotlin/

# ── Build Outputs ────────────────────────────────────────────────────
build/
out/
*.apk
*.aab
*.ipa
*.jar
!gradle/wrapper/gradle-wrapper.jar

# ── IntelliJ / Android Studio ───────────────────────────────────────
*.iml
.idea/
*.iws
*.ipr
*.eml
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
.idea/navEditor.xml
.idea/deploymentTargetDropDown.xml

# ── Android / NDK ────────────────────────────────────────────────────
captures/
.externalNativeBuild/
.cxx/
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/
!*.xcworkspace/contents.xcworkspacedata
**/xcshareddata/WorkspaceSettings.xcsettings
xcuserdata/

# ── macOS ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Windows ───────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Node / Frontend tooling (if any) ─────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── SQLCipher / Database files ────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite

# ── Logs & Crash reports ──────────────────────────────────────────────
*.log
crash_log*.txt

# ── Generated sources (SQLDelight, KSP, BuildConfig) ────────────────
# These are regenerated on build — never commit generated code.
**/generated/
# Note: source .sq files in src/commonMain/sqldelight/ MUST be tracked;
# generated output in build/ is already covered by the build/ rule above.
# Exception: KSP processor configuration
!**/ksp/

# ── Test coverage reports ─────────────────────────────────────────────
**/kover/

# ── Kotlin Notebooks ──────────────────────────────────────────────────
.kotlinnb_cache/

# ── Claude Code agent worktrees (transient, auto-cleaned) ─────────────
.claude/worktrees/
platform-tools.zip
